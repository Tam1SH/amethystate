---
import Card from "../Card.astro"
---
<section class="max-w-[1100px] mx-auto px-8 py-32">
    <p class="text-xl tracking-[0.1em] text-[#7A4699] uppercase mb-4">Why amethystate</p>
    <h2 class="text-4xl font-medium text-[#f0ecfc] mb-4 tracking-tight">Less glue, more app</h2>
    <p class="text-base text-[#9990b8] max-w-lg leading-relaxed mb-12">
        Everything you would write yourself — persistence, subscriptions, migrations — handled for you.
    </p>
    <div class="grid grid-cols-4 gap-4" id="why-cards">
        <Card icon="device-floppy" title="No save layer" text="Writing a field persists it. Debounced flush to disk happens in the background automatically." delay={0} />
        <Card icon="bolt" title="Fine-grained reactivity" text="Subscriptions fire per-field. Compose fields into derived pipelines that recompute automatically." delay={1} />
        <Card icon="git-branch" title="Built-in migrations" text="Version your structs, write a migration step. Runs automatically on startup." delay={2} />
        <Card icon="puzzle" title="Any framework" text="egui, iced, Dioxus, Leptos, Slint, GPUI, Tauri — each with a dedicated integration." delay={3} />
    </div>
</section>