---
import { Code } from 'astro:components';
---
<section class="max-w-[1100px] mx-auto px-8 py-32">
    <p class="text-xl tracking-[0.1em] text-[#7A4699] uppercase mb-4">Migrations</p>
    <h2 class="text-4xl font-medium text-[#f0ecfc] mb-4 tracking-tight">Schema evolution, handled</h2>
    <p class="text-base text-[#9990b8] max-w-lg leading-relaxed mb-12">
        Bump the version, write a step function. The migrator chains them in order and runs on startup before any app code touches the store.
    </p>
    <div class="grid grid-cols-2 gap-12 items-start">
        <div class="space-y-3">
            <div class="bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.07)] rounded-xl p-5">
                <p class="text-xs tracking-widest text-[#7A4699] mb-2">v1</p>
                <code class="text-xs text-[#9990b8] leading-relaxed block">host: String<br/>port: u16</code>
            </div>
            <div class="text-center text-[#4a4560]"><i class="ti ti-arrow-down text-lg"></i></div>
            <div class="bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.07)] rounded-xl p-5">
                <p class="text-xs tracking-widest text-[#7A4699] mb-2">v2</p>
                <code class="text-xs text-[#9990b8] leading-relaxed block">address: String<br/>port: u16<br/>timeout_ms: u64</code>
            </div>
        </div>
        <div class="bg-[rgba(255,255,255,0.03)] border border-[rgba(255,255,255,0.07)] rounded-xl p-6 text-xs leading-relaxed overflow-auto text-[#9990b8]">
            <Code lang="rust" class="!bg-transparent" theme="css-variables" code={`#[migrate]
#[rename(host => address)]
fn migrate_config_v1_to_v2(
    old: AmeData<v1::Config>,
) -> amethystate::Result<AmeData<Config>> {
    Ok(AmeData::<Config> {
        address: old.host,
        port: old.port,
        timeout_ms: 5000,
    })
}`}/>
      </div>
    </div>
</section>