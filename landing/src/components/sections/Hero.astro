---
import { asset } from '../../utils/asset';
---

<section class="min-h-screen flex items-center px-8 relative overflow-hidden">

    <div
            class="absolute pointer-events-none z-[-1]"
            style="
        width: 1400px;
        height: 1100px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(146,112,176,0.12) 70%, rgba(122,70,153,0.06) 35%, transparent 15%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        filter: blur(80px);
    "
    ></div>

    <div class="absolute pointer-events-none" style="
        width: 1000px; height: 500px;
        top: -300px; right: 0%; transform: translateX(50%);
        background: radial-gradient(ellipse, rgba(174,133,187,0.3) 50%, transparent 10%);
        filter: blur(50px);
    "></div>


    <img
            src={asset('/poly-zones.svg')}
            alt=""
            id="hero-poly"
            aria-hidden="true"
            class="absolute left-0 h-full w-auto pointer-events-none opacity-70"
    />

    <div class="absolute inset-0 overflow-hidden z-[-100]">
        <img
                id="hero-bg"
                src={asset('/poly-zones (1).svg')}
                alt=""
                aria-hidden="true"
                class="absolute right-0 h-[170%] w-auto pointer-events-none opacity-10"
                style="top: -35%;"
        />
    </div>


    <div class="max-w-[1100px] mx-auto w-full grid grid-cols-2 gap-16 items-center relative z-10">
        <div>
            <svg width="480" height="65" viewBox="0 0 480 65" class="mb-4">
                <defs>
                    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" stop-color="#7A4699" stop-opacity="0"/>
                        <stop offset="40%" stop-color="#9270B0" stop-opacity="0.7"/>
                        <stop offset="50%" stop-color="#AE85BB" stop-opacity="1"/>
                        <stop offset="60%" stop-color="#9270B0" stop-opacity="0.7"/>
                        <stop offset="100%" stop-color="#7A4699" stop-opacity="0"/>
                        <animateTransform attributeName="gradientTransform" type="translate" from="-1 0" to="2 0" dur="10s" repeatCount="indefinite"/>
                    </linearGradient>
                </defs>
                <text x="0" y="54" font-family="system-ui, sans-serif" font-size="52" font-weight="700" letter-spacing="4" fill="#9270B0">AMETHYSTATE</text>
                <text x="0" y="54" font-family="system-ui, sans-serif" font-size="52" font-weight="700" letter-spacing="4" fill="none" stroke="url(#g)" stroke-width="1.2">AMETHYSTATE</text>
            </svg>
            <p class="text-lg text-[#b6b0c9] leading-relaxed mb-4">
                State management for Rust GUI apps — persistence, reactivity, and migrations without the boilerplate.
            </p>
            <div class="flex gap-3">
                <a href={asset('/getting-started/installation/')} class="bg-[#9270B0] text-[#f0ecfc] rounded-lg px-6 py-2.5 text-sm font-medium">Get started</a>
                <a href="https://github.com/Tam1SH/amethystate" class="border border-[rgba(196,184,232,0.3)] text-[#c4b8e8] rounded-lg px-6 py-2.5 text-sm font-medium flex items-center gap-2">
                    <i class="ti ti-brand-github"></i> GitHub
                </a>
            </div>
        </div>
        <div class="flex items-center justify-center">
            <img src={asset('/logo.svg')} alt="amethystate" class="w-full max-w-[450px] opacity-80" />
        </div>
    </div>
    <div class="absolute bottom-0 left-0 w-full pointer-events-none z-[5]" style="
        height: 1000px;
        background: linear-gradient(to bottom, transparent 0%, #0E0B1A 100%);
    "></div>
    <!--<div class="glow-orb-fast absolute pointer-events-none z-[10]" style="width:550px; height:550px; border-radius:50%; background:radial-gradient(circle, rgba(174,133,187,0.8) 0%, transparent 70%); top:-10%; right:5%;"></div>-->
</section>

<script>
    const bg = document.getElementById('hero-bg');
    const poly = document.getElementById('hero-poly');

    if (bg || poly) {
        window.addEventListener('scroll', () => {
            const y = window.scrollY;
            if (bg)   bg.style.transform   = `translateY(${y * 0.35}px)`;
            if (poly) poly.style.transform = `translateY(${y * 0}px)`;
        }, { passive: true });
    }
</script>

<style>
    @keyframes drift {
        0%   { transform: translate(0px, 0px) scale(1); opacity: 1; }
        25%  { transform: translate(-20px, 25px) scale(1.07); opacity: 0.75; }
        50%  { transform: translate(14px, -18px) scale(0.95); opacity: 0.9; }
        75%  { transform: translate(-10px, 12px) scale(1.03); opacity: 0.8; }
        100% { transform: translate(0px, 0px) scale(1); opacity: 1; }
    }

    @keyframes drift2 {
        0%   { transform: translate(0px, 0px) scale(1); opacity: 1; }
        30%  { transform: translate(22px, -16px) scale(1.1); opacity: 0.65; }
        60%  { transform: translate(-16px, 20px) scale(0.92); opacity: 0.85; }
        80%  { transform: translate(10px, -8px) scale(1.05); opacity: 0.7; }
        100% { transform: translate(0px, 0px) scale(1); opacity: 1; }
    }

    @keyframes drift3 {
        0%   { transform: translate(0px, 0px) scale(1); opacity: 1; }
        20%  { transform: translate(16px, 18px) scale(0.94); opacity: 0.8; }
        55%  { transform: translate(-20px, -12px) scale(1.08); opacity: 0.6; }
        75%  { transform: translate(12px, 8px) scale(0.97); opacity: 0.75; }
        100% { transform: translate(0px, 0px) scale(1); opacity: 1; }
    }

    .glow-orb      { animation: drift  9s  ease-in-out infinite; }
    .glow-orb-slow { animation: drift2 13s ease-in-out infinite; }
    .glow-orb-fast { animation: drift3 11s ease-in-out infinite; }
</style>