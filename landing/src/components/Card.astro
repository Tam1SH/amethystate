---
interface Props {
  icon: string;
  title: string;
  text: string;
  delay?: number;
}
const { icon, title, text, delay = 0 } = Astro.props;
---

<div class="card" data-delay={delay}>
  <div class="card-border">
    <svg aria-hidden="true"><rect x="0.5" y="0.5" rx="11.5" fill="none"/></svg>
  </div>
  <div class="card-icon">
    <i class={`ti ti-${icon}`} aria-hidden="true"></i>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-text">{text}</p>
</div>

<style>
.card {
  position: relative;
  border-radius: 12px;
  padding: 1.5rem;
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(155,116,232,0.15);
}
.card-border {
  position: absolute;
  inset: 0;
  border-radius: 12px;
  pointer-events: none;
}
.card-border svg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  overflow: visible;
}
.card-icon { font-size: 20px; color: #7A4699; margin-bottom: 1rem; }
.card-title { font-size: 14px; font-weight: 500; color: #e8e4f4; margin-bottom: 0.4rem; }
.card-text { font-size: 13px; color: #6e6890; line-height: 1.6; }
</style>
