import { Button, LineEdit } from "std-widgets.slint";

struct ThemeColors {
    primary: string,
    secondary: string,
}

enum ConnectionStatus {
    Disconnected,
    Connecting,
    Connected
}

export global AppTheme {
    in-out property <ThemeColors> colors;
    in-out property <bool> dark-mode;
    in property <string> version-label;
}

export global NetworkConfig {
    in-out property <string> host;
    in-out property <string> port-text;
    in-out property <string> address;
}

export component TestWindow inherits Window {
    in-out property <string> host;
    in-out property <string> port-text;
    in-out property <string> address;
    in-out property <bool> connected;
    in-out property <int> retry-count;
    in-out property <ConnectionStatus> status;
    in property <string> status-label;
    out property <int> click-count;
}